APP_LISTEN_ADDR=:5298
APP_DB_PATH=./data/app.db

# When true, deployments fail with an explicit error (no simulation).
# Set to false to enable real deployments.
DRY_RUN=false

# If set, used to derive an AES key to encrypt settings in SQLite.
APP_ENC_KEY=change-me-strong-passphrase

# Force secure cookies (set to true when running behind HTTPS).
APP_SECURE_COOKIE=false

# If true, the Proxmox client will skip TLS certificate verification.
# Useful in a lab with self-signed Proxmox certificates. DO NOT enable on internet-facing setups.
APP_PROXMOX_INSECURE_TLS=false

# Network allocation for auto IPs (optional but recommended if you don't want
# to manually enter IP/gateway/DNS for each deployment).
# Example for home lab:
#   APP_NET_CIDR=192.168.1.0/24
#   APP_NET_GATEWAY=192.168.1.1
#   APP_NET_DNS=1.1.1.1
APP_NET_CIDR=
APP_NET_GATEWAY=
APP_NET_DNS=
APP_HOSTNAME_PREFIX=mc-

# Cache directory for Hytale server files (HytaleServer.jar, assets). The internal downloader
# populates this automatically via OAuth (auth:downloader). If unset, defaults to
# /opt/proxmox-game-deployer/hytale-server-files. Configure both server and downloader auth
# in the Hytale settings page before deploying.
# Example:
#   HYTALE_SERVER_FILES_DIR=/opt/hytale-server-files
HYTALE_SERVER_FILES_DIR=

# Optional override for Ansible playbook path.
# ANSIBLE_PLAYBOOK_PATH=/opt/proxmox-game-deployer/ansible/provision_minecraft.yml

# Path to the SSH private key used by Ansible to connect to game VMs.
# IMPORTANT: this key must be readable by the system user running the
# service (proxmox by default). Example setup:
#   mkdir -p /opt/proxmox-game-deployer/ssh
#   cp ~/.ssh/id_ed25519 /opt/proxmox-game-deployer/ssh/
#   chown proxmox:proxmox /opt/proxmox-game-deployer/ssh/id_ed25519
#   chmod 600 /opt/proxmox-game-deployer/ssh/id_ed25519
# Then set:
#   APP_SSH_KEY_PATH=/opt/proxmox-game-deployer/ssh/id_ed25519
APP_SSH_KEY_PATH=

